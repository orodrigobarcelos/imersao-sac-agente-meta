# =============================================================================
# CREDENCIAIS META — OBRIGATORIAS
# =============================================================================
# Veja META_APP_SETUP.md (na raiz) para o passo a passo de criacao do app Meta
# e geracao do token com as 9 permissoes necessarias.
# =============================================================================

# Token de acesso Meta (Graph API Explorer)
# https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=

# App ID (developers.facebook.com/apps -> Configuracoes -> Basicas)
META_APP_ID=

# App Secret (mesma tela do App ID, clicar "Mostrar")
META_APP_SECRET=


# =============================================================================
# SERVIDOR
# =============================================================================
# Porta do servidor MCP local (padrao 8080)
PORT=8080


# =============================================================================
# OPCIONAL — flags de funcionalidade
# =============================================================================
# Defina como "1" para desativar
# META_ADS_DISABLE_LOGIN_LINK=
# META_ADS_DISABLE_CALLBACK_SERVER=
# META_ADS_DISABLE_ADS_LIBRARY=
